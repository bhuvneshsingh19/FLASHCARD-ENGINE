{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx", // next.js uses the React automatic runtime
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "target": "ES2017", // Next.js 16 suggest value
    
    // *** ENSURE THIS PART IS EXACTLY LIKE THIS OR YOUR IMPORTS WILL BREAK ***
    "paths": {
      "@/*": ["./src/*"] 
    }
  },
  "include": [
    "next-env.d.ts", 
    "**/*.ts", 
    "**/*.tsx", 
    ".next/types/**/*.ts", 
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}